[core]
	autocrlf = true
	pager = delta --paging=always
[interactive]
  diffFilter = delta --color-only
[delta]
	line-numbers = true
	side-by-side = true
  navigate = true
  true-color = always
  features = catppuccin-mocha
[merge]
    conflictStyle = zdiff3
[include]
    path = ~/.config/sm-windows-terminal-profiles/powershell/profile/modules/delta/catppuccin.gitconfig
